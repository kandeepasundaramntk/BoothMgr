# Copy to .env.local and fill in from your Supabase project settings (Project Settings → API).
# Never commit .env.local.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Set to "1" to run without Supabase using in-browser demo data (for local evaluation only).
# VITE_DEMO=1
